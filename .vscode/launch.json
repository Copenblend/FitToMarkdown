{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FitToMarkdown.Cli",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/FitToMarkdown.Cli/bin/Debug/net10.0/FitToMarkdown.Cli.dll",
      "args": [],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "stopAtEntry": false
    },
    {
      "name": "FitToMarkdown.Cli (with file)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/FitToMarkdown.Cli/bin/Debug/net10.0/FitToMarkdown.Cli.dll",
      "args": ["${input:fitFilePath}"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "stopAtEntry": false
    }
  ],
  "inputs": [
    {
      "id": "fitFilePath",
      "type": "promptString",
      "description": "Path to.fit file to process",
      "default": ""
    }
  ]
}
